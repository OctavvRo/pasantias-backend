{
  "info": {
    "name": "Users API",
    "description": "API endpoints for User management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"user\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "users"
          ]
        }
      }
    },
    {
      "name": "Get All Users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/users?page=1&limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "name",
              "value": "",
              "disabled": true
            },
            {
              "key": "role",
              "value": "user",
              "disabled": true
            }
          ]
        }
      }
    },
    {
      "name": "Get User by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/users/:userId",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "users",
            ":userId"
          ],
          "variable": [
            {
              "key": "userId",
              "value": "REPLACE_WITH_ID"
            }
          ]
        }
      }
    },
    {
      "name": "Update User",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Updated\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/users/:userId",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "users",
            ":userId"
          ],
          "variable": [
            {
              "key": "userId",
              "value": "REPLACE_WITH_ID"
            }
          ]
        }
      }
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/users/:userId",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "users",
            ":userId"
          ],
          "variable": [
            {
              "key": "userId",
              "value": "REPLACE_WITH_ID"
            }
          ]
        }
      }
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "REPLACE_WITH_YOUR_TOKEN",
      "type": "string"
    }
  ]
}
