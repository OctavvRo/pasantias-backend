{
  "info": {
    "name": "Products API",
    "description": "API endpoints for the Product module",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Product",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Teclado Mecánico\",\n  \"description\": \"Teclado RGB con switches azules\",\n  \"price\": 45.99,\n  \"category\": \"Periféricos\",\n  \"stock\": 15\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "products"
          ]
        }
      }
    },
    {
      "name": "Get All Products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/products?page=1&limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "products"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "name",
              "value": "",
              "disabled": true
            },
            {
              "key": "category",
              "value": "Periféricos",
              "disabled": true
            }
          ]
        }
      }
    },
    {
      "name": "Get Product by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/products/:productId",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "products",
            ":productId"
          ],
          "variable": [
            {
              "key": "productId",
              "value": "REPLACE_WITH_ID"
            }
          ]
        }
      }
    },
    {
      "name": "Update Product",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"price\": 39.99,\n  \"stock\": 10\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/products/:productId",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "products",
            ":productId"
          ],
          "variable": [
            {
              "key": "productId",
              "value": "REPLACE_WITH_ID"
            }
          ]
        }
      }
    },
    {
      "name": "Delete Product",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/products/:productId",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "products",
            ":productId"
          ],
          "variable": [
            {
              "key": "productId",
              "value": "REPLACE_WITH_ID"
            }
          ]
        }
      }
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "REPLACE_WITH_YOUR_TOKEN",
      "type": "string"
    }
  ]
}
